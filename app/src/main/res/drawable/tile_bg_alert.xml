<?xml version="1.0" encoding="utf-8"?>
<!-- Card with a status-colored left stripe that follows the 14dp corner curve. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- status silhouette (shows through as the left stripe + rounded left corners) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/cw_tone_danger_solid_bg"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <!-- card surface, inset 4dp from the left to reveal the stripe -->
    <item android:left="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/cw_bg_surface_elevated"/>
            <corners
                android:topLeftRadius="10dp" android:bottomLeftRadius="10dp"
                android:topRightRadius="14dp" android:bottomRightRadius="14dp"/>
        </shape>
    </item>
</layer-list>
