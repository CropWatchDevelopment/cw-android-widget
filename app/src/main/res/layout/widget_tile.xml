<?xml version="1.0" encoding="utf-8"?>
<!-- One device row in the vertically-scrolling list (ListView item). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tile_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:minHeight="58dp"
    android:orientation="horizontal"
    android:background="@drawable/tile_bg_online">

    <!-- left: location + name + secondary/last-seen (status stripe is baked into the bg) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/tile_loc_icon"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="3dp"
                android:src="@drawable/ic_location_on" />

            <TextView
                android:id="@+id/tile_location"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/cw_text_muted"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:text="Warehouse 1" />
        </LinearLayout>

        <TextView
            android:id="@+id/tile_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/cw_text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="Cold Room A · Rack 3" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/tile_sec_icon"
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_humidity_percentage" />

            <TextView
                android:id="@+id/tile_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginEnd="10dp"
                android:textColor="@color/cw_text_muted"
                android:textSize="10sp"
                android:text="47 %RH" />

            <ImageView
                android:id="@+id/tile_seen_icon"
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:layout_marginEnd="3dp"
                android:src="@drawable/ic_schedule" />

            <TextView
                android:id="@+id/tile_seen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/cw_text_muted"
                android:textSize="10sp"
                android:text="1m ago" />
        </LinearLayout>
    </LinearLayout>

    <!-- right: alert badge + big primary reading -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="end|center_vertical"
        android:paddingEnd="13dp"
        android:paddingStart="4dp">

        <TextView
            android:id="@+id/tile_alert_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginBottom="4dp"
            android:visibility="gone"
            android:background="@drawable/bg_alert_badge"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="@color/cw_tone_danger_solid_text"
            android:textSize="8sp"
            android:textStyle="bold"
            android:text="ALERT" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="true"
            android:gravity="bottom|end">

            <TextView
                android:id="@+id/tile_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cw_text_primary"
                android:textSize="23sp"
                android:textStyle="bold"
                android:text="−18.2" />

            <TextView
                android:id="@+id/tile_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:layout_marginBottom="2dp"
                android:textColor="@color/cw_text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="°C" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
